# Base URL of the EmberQA backend's authenticated API (no trailing slash).
# Dev points at the local backend; prod at the deployed backend.
VITE_API_BASE=http://localhost:3001

# Base URL of the UNAUTHENTICATED dialer-auth router (handoff exchange).
# Same host as the backend, mounted outside /api/v1. Usually VITE_API_BASE host
# + /dialer-auth/v1 — kept separate in case it ever differs.
VITE_DIALER_AUTH_BASE=http://localhost:3001/dialer-auth/v1
